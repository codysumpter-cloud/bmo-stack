# Copy to ~/.config/bmo-runtime.env and customize as needed

# Core local runtime models
BMO_TEXT_MODEL=gemma3:1b
BMO_VISION_MODEL=moondream

# Runtime behavior
BMO_TTS_MODE=auto
BMO_OLLAMA_TIMEOUT_SEC=60
BMO_MAX_RESPONSE_SENTENCES=4
BMO_SYSTEM_PROMPT_EXTRAS='Keep responses concise, practical, and BMO-like.'

# Optional runtime paths
BMO_RUNTIME_ENV_FILE=$HOME/.config/bmo-runtime.env
BMO_FACE_ASSET_DIR=
BMO_CAPTURE_IMAGE=
