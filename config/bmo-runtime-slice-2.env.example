# Copy to ~/.config/bmo-runtime.env and customize as needed

# Core text runtimes
BMO_TEXT_MODEL=nemotron-mini:4b-instruct-q2_K
BMO_LOCAL_TEXT_MODEL=nemotron-mini:4b-instruct-q2_K
BMO_CLOUD_TEXT_MODEL=nemotron-3-super
BMO_CLOUD_TEXT_ENDPOINT=
BMO_CLOUD_API_STYLE=openai
BMO_CLOUD_API_KEY=

# Vision and audio
BMO_VISION_MODEL=moondream
BMO_TTS_MODE=auto
BMO_STT_BACKEND=typed
BMO_STT_COMMAND=
BMO_WAKE_WORD=off
BMO_WAKE_WORD_PHRASE='hey bmo'

# Routing and response behavior
BMO_FACE_RENDERER=basic
BMO_FACE_SCRIPT=
BMO_MODEL_ROUTE_DEFAULT=local
BMO_OLLAMA_TIMEOUT_SEC=45
BMO_MAX_RESPONSE_SENTENCES=4
BMO_SYSTEM_PROMPT_EXTRAS='Keep responses concise, practical, and BMO-like.'
