# Copy to ~/.config/bmo-omni.env and customize as needed

# Where omni-bmo should live locally
OMNI_BMO_DIR=$HOME/.bmo-stack/omni-bmo

# Omni endpoint used by omni-bmo when llm_backend=omni
BMO_OMNI_BASE_URL=http://127.0.0.1:8799/api/omni

# Optional token for PrismBot/Omni-backed requests
# Prefer exporting PRISMBOT_API_TOKEN in your shell or secret manager.
# BMO_OMNI_TOKEN is supported as a local convenience override.
BMO_OMNI_TOKEN=

# Optional explicit env file path override used by helper scripts
BMO_OMNI_ENV_FILE=$HOME/.config/bmo-omni.env
