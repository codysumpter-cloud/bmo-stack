# Shared NVIDIA / NGC credentials
# Fill these locally. Never commit real secrets.
NGC_API_KEY=
NVIDIA_API_KEY=

# Shared feature toggles for bmo-stack surfaces
BMO_NVIDIA_ENABLE_SAFETY_GUARDRAILS=true
BMO_NVIDIA_ENABLE_AIQ_RESEARCH_MODE=false
BMO_NVIDIA_ENABLE_VOICE_AGENT=false
BMO_NVIDIA_ENABLE_PDF_TO_PODCAST=false
BMO_NVIDIA_ENABLE_RETAIL_BLUEPRINT_PATTERNS=false

# Optional external service endpoints
BMO_NVIDIA_VOICE_AGENT_URL=http://localhost:8081
BMO_NVIDIA_PDF_TO_PODCAST_URL=http://localhost:8082
BMO_NVIDIA_AIQ_URL=http://localhost:8083
BMO_NVIDIA_SAFETY_URL=http://localhost:8084

# Optional shared model defaults
BMO_NVIDIA_TEXT_MODEL=llama-3.3-nemotron-super-49b-v1.5
BMO_NVIDIA_REASONING_MODEL=nemotron-nano-12b-v2
BMO_NVIDIA_EMBED_MODEL=llama-3.2-nv-embedqa-1b-v2

# Notes
# - bmo-stack should treat warehouse, telco, weather, and AI-factory workflows
#   as external specialist integrations instead of bundling them into the local
#   desktop/runtime by default.
# - Use `automindlab-stack` as the primary runtime owner for enterprise /
#   vertical NVIDIA blueprint services.
