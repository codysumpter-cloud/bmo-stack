{
  "version": 1,
  "manifest_id": "bmo-founder-os",
  "description": "Role-scoped founder operating system manifest for BMO's always-on operator workflows.",
  "sharedMemoryFiles": [
    "memory/company.md",
    "memory/product.md",
    "memory/voice.md",
    "memory/customers.md",
    "memory/market.md"
  ],
  "roleMemoryRoot": "memory/agents",
  "workflowManifest": "config/workflows/founder-os-workflows.json",
  "scheduleManifest": "config/scheduler/founder-os-schedule.json",
  "routerPolicy": "config/router/model-routing-policy.json",
  "dashboardManifest": "config/operator/mission-control.manifest.json",
  "roles": [
    {
      "id": "orchestrator",
      "name": "Prismo",
      "operatingRole": "orchestrator",
      "objective": "Own task routing, handoffs, and final decision boundaries for founder workflows.",
      "councilMapping": ["Prismo", "BMO", "NEPTR"],
      "memoryFile": "memory/agents/orchestrator.md",
      "tools": ["docs", "repo-context", "scheduler-contracts", "workflow-contracts"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["researcher", "writer", "dev", "ops-assistant"], "verification": ["qa-monitor"]},
      "scheduleRefs": ["morning-brief", "midday-trend-scan", "end-of-day-review"],
      "modelPolicy": "long-context-synthesis",
      "verification": {"required": true, "reviewQueue": "operator"}
    },
    {
      "id": "researcher",
      "name": "Atlas",
      "operatingRole": "research",
      "objective": "Find user pain, competitor movement, market shifts, and evidence-backed opportunities.",
      "councilMapping": ["Simon", "Princess Bubblegum"],
      "memoryFile": "memory/agents/researcher.md",
      "tools": ["web-search", "docs", "market-watch"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["writer", "trend-scout", "growth-outreach"]},
      "scheduleRefs": ["morning-brief", "midday-trend-scan"],
      "modelPolicy": "deep-research",
      "verification": {"required": true, "reviewQueue": "research"}
    },
    {
      "id": "writer",
      "name": "Scribe",
      "operatingRole": "writing",
      "objective": "Turn research and briefs into clean drafts for posts, docs, and operator-facing updates.",
      "councilMapping": ["Marceline", "BMO"],
      "memoryFile": "memory/agents/writer.md",
      "tools": ["docs", "voice-guide", "workflow-contracts"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["growth-outreach", "ops-assistant"]},
      "scheduleRefs": ["research-to-draft", "midday-trend-scan"],
      "modelPolicy": "cheap-reasoner",
      "verification": {"required": true, "reviewQueue": "content"}
    },
    {
      "id": "trend-scout",
      "name": "Signal Scout",
      "operatingRole": "trend-scout",
      "objective": "Watch channels and topics that can trigger timely content, response, or product follow-up.",
      "councilMapping": ["Simon", "Jake"],
      "memoryFile": "memory/agents/trend-scout.md",
      "tools": ["web-search", "market-watch", "workflow-contracts"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["researcher", "writer", "growth-outreach"]},
      "scheduleRefs": ["midday-trend-scan"],
      "modelPolicy": "cheap-reasoner",
      "verification": {"required": true, "reviewQueue": "research"}
    },
    {
      "id": "dev",
      "name": "Builder",
      "operatingRole": "development",
      "objective": "Implement bounded code tasks with explicit contracts, artifacts, and rollback notes.",
      "councilMapping": ["Finn", "Princess Bubblegum"],
      "memoryFile": "memory/agents/dev.md",
      "tools": ["repo-context", "tests", "workflow-contracts"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["code-review", "qa-monitor"]},
      "scheduleRefs": ["code-implement-review"],
      "modelPolicy": "coding",
      "verification": {"required": true, "reviewQueue": "code"}
    },
    {
      "id": "code-review",
      "name": "Reviewer",
      "operatingRole": "code-review",
      "objective": "Audit patches for correctness, maintainability, and repo-boundary compliance before human approval.",
      "councilMapping": ["NEPTR", "Peppermint Butler", "Princess Bubblegum"],
      "memoryFile": "memory/agents/code-reviewer.md",
      "tools": ["repo-context", "tests", "diff-review"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": false},
      "handoffs": {"success": ["qa-monitor", "orchestrator"]},
      "scheduleRefs": ["code-implement-review"],
      "modelPolicy": "verification",
      "verification": {"required": true, "reviewQueue": "code"}
    },
    {
      "id": "qa-monitor",
      "name": "NEPTR Ops",
      "operatingRole": "qa-monitor",
      "objective": "Verify task completion claims, detect regressions, and keep risky runs out of done-state.",
      "councilMapping": ["NEPTR", "Lemongrab", "Flame Princess"],
      "memoryFile": "memory/agents/qa-monitor.md",
      "tools": ["tests", "browser-proof", "run-logs"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": false},
      "handoffs": {"success": ["orchestrator", "ops-assistant"]},
      "scheduleRefs": ["bug-monitor-triage", "end-of-day-review"],
      "modelPolicy": "verification",
      "verification": {"required": true, "reviewQueue": "quality"}
    },
    {
      "id": "growth-outreach",
      "name": "Outreach Drafter",
      "operatingRole": "growth",
      "objective": "Draft human-reviewed outreach, community replies, and distribution-ready follow-ups.",
      "councilMapping": ["Marceline", "BMO", "Jake"],
      "memoryFile": "memory/agents/growth-outreach.md",
      "tools": ["docs", "voice-guide", "community-context"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["ops-assistant", "orchestrator"]},
      "scheduleRefs": ["research-to-draft", "midday-trend-scan"],
      "modelPolicy": "cheap-reasoner",
      "verification": {"required": true, "reviewQueue": "content"}
    },
    {
      "id": "ops-assistant",
      "name": "Operator Assistant",
      "operatingRole": "ops",
      "objective": "Prepare dashboards, queues, and status summaries so the founder can review the system quickly.",
      "councilMapping": ["BMO", "Jake", "Simon"],
      "memoryFile": "memory/agents/ops-assistant.md",
      "tools": ["run-logs", "dashboard-contracts", "workflow-contracts"],
      "permissions": {"canPost": false, "canOpenPr": false, "canMutateMemory": true},
      "handoffs": {"success": ["orchestrator"]},
      "scheduleRefs": ["end-of-day-review"],
      "modelPolicy": "cheap-reasoner",
      "verification": {"required": true, "reviewQueue": "operator"}
    }
  ]
}
