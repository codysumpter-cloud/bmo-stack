# Copy this file to config/github/codespace-codex.env and fill in local values.

# Optional. Leave blank to use the CLI default model.
BMO_CODEX_MODEL=

# Common values include read-only, workspace-write, or full-auto style modes depending on your Codex setup.
BMO_CODEX_SANDBOX=workspace-write

# Optional file to capture the final Codex message.
BMO_CODEX_OUTPUT_FILE=
