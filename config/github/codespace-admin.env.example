# Copy this file to config/github/codespace-admin.env and fill in local values.

BMO_AUTONOMY_EXECUTION_ENABLED=false
BMO_WORKSPACE_SYNC_ENABLED=false
BMO_GITHUB_AUTONOMY_EXECUTOR=/absolute/path/to/bmo-github-executor
BMO_OPENCLAW_HOST_WORKSPACE=$HOME/.openclaw/workspace-bmo-host
BMO_OPENCLAW_WORKER_WORKSPACE=$HOME/.openclaw/workspace-bmo-worker
