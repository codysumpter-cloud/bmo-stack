{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bemore.dev/contracts/capabilities/skill-package.schema.json",
  "title": "BeMore Skill Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "owner",
    "permissions",
    "runtime",
    "schemas",
    "artifacts",
    "events",
    "install",
    "ui",
    "binding"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "stability": { "type": "string", "enum": ["draft", "mvp", "stable", "deprecated"] },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "domain"],
      "properties": {
        "repo": { "type": "string", "enum": ["BeMore-stack"] },
        "domain": { "type": "string", "enum": ["brain"] },
        "maintainers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "requiredTools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handler", "capabilities"],
      "properties": {
        "handler": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "noMiniRuntime": { "type": "boolean", "const": true }
      }
    },
    "schemas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output"],
      "properties": {
        "input": { "type": "string" },
        "output": { "type": "string" },
        "config": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configSchema", "approvalRequired"],
      "properties": {
        "configSchema": { "type": "string" },
        "approvalRequired": { "type": "boolean" },
        "defaultConfig": { "type": "object" }
      }
    },
    "validationHooks": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discovery", "launchRoute"],
      "properties": {
        "discovery": { "type": "boolean" },
        "launchRoute": { "type": "string" },
        "icon": { "type": "string" },
        "surfaceHooks": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedTargetKinds", "defaultRole"],
      "properties": {
        "allowedTargetKinds": {
          "type": "array",
          "items": { "type": "string", "enum": ["skill", "app"] },
          "uniqueItems": true
        },
        "defaultRole": { "type": "string" },
        "resumePolicy": { "type": "string", "enum": ["latest-artifact", "session", "none"] }
      }
    }
  }
}
